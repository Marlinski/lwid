# lwid deployment secrets
# Copy this file to .env and fill in the values.

# Redis password (pick a strong random string)
REDIS_PASSWORD=

# JuiceFS S3 backend credentials
JUICEFS_NAME=lwid
JUICEFS_METAURL=redis://:${REDIS_PASSWORD}@redis.lwid.svc:6379/0
JUICEFS_STORAGE=s3
JUICEFS_BUCKET=https://s3.gra.io.cloud.ovh.net/lwid-storage
JUICEFS_ACCESS_KEY=
JUICEFS_SECRET_KEY=

# OVH API credentials (for cert-manager DNS-01 challenge on lookwhatidid.ovh)
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=
